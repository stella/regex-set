{
  "name": "@stll/regex-set",
  "version": "0.1.0",
  "description": "NAPI-RS bindings to Rust regex-automata for multi-pattern regex matching in Node.js/Bun",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/stella/regex-set"
  },
  "homepage": "https://github.com/stella/regex-set#readme",
  "bugs": {
    "url": "https://github.com/stella/regex-set/issues"
  },
  "keywords": [
    "regex",
    "regex-set",
    "multi-pattern",
    "napi-rs",
    "native",
    "rust"
  ],
  "main": "lib.js",
  "module": "lib.mjs",
  "types": "lib.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./lib.d.ts",
        "default": "./lib.mjs"
      },
      "require": {
        "types": "./lib.d.ts",
        "default": "./lib.js"
      }
    }
  },
  "browser": {
    "./lib.js": "./lib.wasm.js",
    "./lib.mjs": "./lib.wasm.js"
  },
  "files": [
    "lib.js",
    "lib.mjs",
    "lib.d.ts",
    "lib.wasm.js",
    "index.js",
    "index.d.ts"
  ],
  "napi": {
    "binaryName": "regex-set",
    "targets": [
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "x86_64-unknown-linux-gnu",
      "aarch64-unknown-linux-gnu",
      "x86_64-unknown-linux-musl",
      "x86_64-pc-windows-msvc"
    ]
  },
  "scripts": {
    "build": "napi build --platform --release",
    "build:debug": "napi build --platform",
    "build:wasm": "napi build --target wasm32-wasip1-threads --release",
    "artifacts": "napi artifacts",
    "universal": "napi universal",
    "prepublishOnly": "napi prepublish -t npm",
    "test": "bun test __test__/index.spec.ts",
    "test:props": "bun test __test__/properties.spec.ts",
    "format": "oxfmt . && rustfmt src/lib.rs",
    "lint": "oxlint .",
    "bench": "bun __bench__/speed.ts",
    "bench:install": "cd __bench__ && bun install",
    "bench:download": "bash __bench__/download-corpus.sh"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.0.0",
    "@types/node": "^25.5.0",
    "bun-types": "^1.3.10",
    "fast-check": "^4.6.0",
    "oxfmt": "^0.40.0",
    "oxlint": "^1.55.0"
  },
  "engines": {
    "node": ">= 18"
  },
  "optionalDependencies": {
    "@stll/regex-set-darwin-arm64": "0.1.0",
    "@stll/regex-set-darwin-x64": "0.1.0",
    "@stll/regex-set-linux-arm64-gnu": "0.1.0",
    "@stll/regex-set-linux-x64-gnu": "0.1.0",
    "@stll/regex-set-linux-x64-musl": "0.1.0",
    "@stll/regex-set-win32-x64-msvc": "0.1.0"
  }
}
