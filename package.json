{
  "name": "@stll/regex-set",
  "version": "1.0.0-rc.2",
  "description": "Single-pass multi-pattern regex for Node.js/Bun. Backtracking-immune, Unicode-aware Rust engine via NAPI-RS.",
  "keywords": [
    "multi-pattern",
    "napi-rs",
    "native",
    "regex",
    "regex-set",
    "rust"
  ],
  "homepage": "https://github.com/stella/regex-set#readme",
  "bugs": {
    "url": "https://github.com/stella/regex-set/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stella/regex-set.git"
  },
  "files": [
    "dist",
    "index.cjs"
  ],
  "type": "module",
  "module": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "fix:loader": "node scripts/fix-napi-loader.mjs",
    "build": "node scripts/build-native.mjs --platform --release",
    "build:debug": "node scripts/build-native.mjs --platform",
    "build:wasm": "node scripts/build-native.mjs --platform --target wasm32-wasip1-threads --release",
    "build:js": "node scripts/ensure-wasm-artifact.mjs && tsdown",
    "artifacts": "napi artifacts",
    "universal": "napi universal",
    "prepublishOnly": "napi prepublish -t npm && node scripts/fix-napi-loader.mjs && tsdown",
    "test": "bun test __test__/index.spec.ts",
    "test:props": "bun test __test__/properties.spec.ts",
    "test:runtime:bun": "bun scripts/runtime-smoke.mjs",
    "test:runtime:node": "node scripts/runtime-smoke.mjs",
    "version:sync": "node scripts/version-sync.mjs sync",
    "version:check": "node scripts/version-sync.mjs check",
    "format": "oxfmt . && rustfmt src/lib.rs",
    "lint": "oxlint .",
    "bench": "bun __bench__/speed.ts",
    "bench:all": "bun run bench && bun run bench:fallback",
    "bench:fallback": "bun __bench__/fancy-fallback.ts",
    "bench:install": "cd __bench__ && bun install",
    "bench:download": "bash __bench__/download-corpus.sh"
  },
  "devDependencies": {
    "@emnapi/core": "^1.9.2",
    "@emnapi/runtime": "^1.9.2",
    "@napi-rs/cli": "^3.6.1",
    "@napi-rs/wasm-runtime": "^1.1.3",
    "@tybys/wasm-util": "^0.10.1",
    "@types/node": "^25.5.2",
    "bun-types": "^1.3.11",
    "emnapi": "^1.9.2",
    "fast-check": "^4.6.0",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.59.0",
    "tsdown": "^0.21.7",
    "typescript": "^6.0.2",
    "vite": "^8.0.8"
  },
  "optionalDependencies": {
    "@stll/regex-set-darwin-arm64": "1.0.0-rc.2",
    "@stll/regex-set-darwin-x64": "1.0.0-rc.2",
    "@stll/regex-set-linux-arm64-gnu": "1.0.0-rc.2",
    "@stll/regex-set-linux-x64-gnu": "1.0.0-rc.2",
    "@stll/regex-set-wasm32-wasi": "1.0.0-rc.2"
  },
  "napi": {
    "binaryName": "regex-set",
    "targets": [
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "x86_64-unknown-linux-gnu",
      "aarch64-unknown-linux-gnu",
      "wasm32-wasip1-threads"
    ]
  },
  "engines": {
    "node": ">= 18"
  }
}
