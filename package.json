{
  "name": "@stll/regex-set",
  "version": "0.5.1",
  "description": "Multi-pattern regex for Node.js/Bun. 2-9x faster than JS RegExp, backtracking-immune, Unicode word boundaries. Rust DFA engine via NAPI-RS.",
  "keywords": [
    "multi-pattern",
    "napi-rs",
    "native",
    "regex",
    "regex-set",
    "rust"
  ],
  "homepage": "https://github.com/stella/regex-set#readme",
  "bugs": {
    "url": "https://github.com/stella/regex-set/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/stella/regex-set"
  },
  "files": [
    "dist",
    "index.js",
    "index.d.ts"
  ],
  "type": "module",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "napi build --platform --release",
    "build:debug": "napi build --platform",
    "build:wasm": "napi build --target wasm32-wasip1-threads --release",
    "artifacts": "napi artifacts",
    "universal": "napi universal",
    "build:js": "tsdown",
    "prepublishOnly": "napi prepublish -t npm && tsdown",
    "test": "bun test __test__/index.spec.ts",
    "test:props": "bun test __test__/properties.spec.ts",
    "format": "oxfmt . && rustfmt src/lib.rs",
    "lint": "oxlint .",
    "bench": "bun __bench__/speed.ts",
    "bench:install": "cd __bench__ && bun install",
    "bench:download": "bash __bench__/download-corpus.sh"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.0.0",
    "@types/node": "^25.5.0",
    "bun-types": "^1.3.11",
    "fast-check": "^4.6.0",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.55.0",
    "tsdown": "^0.12.4"
  },
  "optionalDependencies": {
    "@stll/regex-set-darwin-arm64": "0.5.0",
    "@stll/regex-set-darwin-x64": "0.5.0",
    "@stll/regex-set-linux-arm64-gnu": "0.5.0",
    "@stll/regex-set-linux-x64-gnu": "0.5.0"
  },
  "napi": {
    "binaryName": "regex-set",
    "targets": [
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "x86_64-unknown-linux-gnu",
      "aarch64-unknown-linux-gnu"
    ]
  },
  "engines": {
    "node": ">= 18"
  }
}
