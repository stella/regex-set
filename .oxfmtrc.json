{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "ignorePatterns": [
    "*.node",
    "npm/",
    "index.cjs",
    "index.d.ts"
  ],
  "printWidth": 60,
  "sortImports": {
    "customGroups": [
      {
        "groupName": "stella",
        "elementNamePattern": ["@stella/**"]
      }
    ],
    "groups": [
      [
        "value-builtin",
        "value-external",
        "type-builtin",
        "type-external"
      ],
      "stella",
      [
        "value-parent",
        "value-sibling",
        "value-index",
        "type-parent",
        "type-sibling",
        "type-index"
      ]
    ],
    "newlinesBetween": true
  }
}
